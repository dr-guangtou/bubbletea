# ======================================
# BubbleTea project .gitignore
# ======================================

# Legacy code (frozen reference)
ucd_project/

# Legacy directories to be archived
notebooks/archive/
doc/sql/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.env
.venv
env/
venv/

# Data files (large, binary)
*.fits
*.fits.gz
*.fits.fz
*.db
*.sqlite
*.sqlite3
data/external/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Ruff
.ruff_cache/

# Sphinx / docs build
docs/_build/

# Keep gitkeep files
!.gitkeep
